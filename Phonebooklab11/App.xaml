<Application x:Class="Phonebooklab11.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Phonebooklab11"
             xmlns:vm="clr-namespace:Phonebooklab11.ViewModels"
             xmlns:view="clr-namespace:Phonebooklab11.View">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:ContactsListViewModel}">
            <view:ContactsListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContactEditViewModel}">
            <view:ContactEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <view:AboutView />
        </DataTemplate>
    </Application.Resources>
</Application>
