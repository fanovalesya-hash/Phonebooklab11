<UserControl x:Class="Phonebooklab11.View.ContactEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Phonebooklab11.View"
        mc:Ignorable="d" Height="450" Width="800">
    <StackPanel Margin="20" VerticalAlignment="Top">
        <TextBlock Text="Редактирование контакта" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Text="Имя:" Margin="0,5"/>
        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <TextBlock Text="Телефон:" Margin="0,10,0,5"/>
        <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="100" Margin="0,0,10,0"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100"/>
        </StackPanel>
    </StackPanel>
</UserControl>
