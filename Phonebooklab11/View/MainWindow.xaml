<Window x:Class="Phonebooklab11.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Phonebooklab11.View"
        mc:Ignorable="d"
        Title="Телефонная книжка" Height="450" Width="800">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="LightGray" Height="45">
            <Button Content="Контакты" Command="{Binding ShowContactsCommand}" 
                Margin="10,0,5,0" Padding="12,4" FontSize="14"/>
            <Button Content="О программе" Command="{Binding ShowAboutCommand}" 
                Margin="5,0,10,0" Padding="12,4" FontSize="14"/>
        </StackPanel>

        <ContentControl Content="{Binding NavigationService.CurrentViewModel}" Margin="10"/>
    </DockPanel>
</Window>
